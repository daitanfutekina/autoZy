{
  "manifest_version": 3,
  "name": "AutoZy",
  "version": "2.0.0",
  "description": "Automates zyBooks participation activities.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://learn.zybooks.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
